{
  "manifest_version": 3,
  "name": "Smart Reply Assist",
  "short_name": "Smart Reply",
  "version": "1.0.0",
  "description": "Cyberpunk-themed AI assistant for translation and message composition.",
  "start_url": ".",
  "display": "standalone",
  "theme_color": "#050505",
  "background_color": "#050505",
  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "system.display"
  ],
  "action": {
    "default_title": "Smart Reply Assist",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": [
    {
      "src": "icon16.png",
      "sizes": "16x16",
      "type": "image/png"
    },
    {
      "src": "icon48.png",
      "sizes": "48x48",
      "type": "image/png"
    },
    {
      "src": "icon128.png",
      "sizes": "128x128",
      "type": "image/png"
    },
    {
      "src": "icon192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
